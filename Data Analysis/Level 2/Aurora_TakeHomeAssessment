        "import matplotlib.pyplot as plt\n",
        "\n",
        "years = [2016, 2017, 2018, 2019, 2020, 2021]\n",
        "construction_hours = [87.352119, 137.432209, 179.309039, 453.738006, 464.715078, 1371.736645]\n",
        "plt.figure()\n",
        "\n",
        "plt.plot(years, construction_hours, marker='o')\n",
        "\n",
        "# Labels and title\n",
        "plt.xlabel(\"Year\")\n",
        "plt.ylabel(\"Construction Hours (Millions)\")\n",
        "plt.title(\"Construction Hours Trend Over Time\")\n",
        "\n",
        "plt.grid()\n",
        "\n",
        "plt.show()"
      ],
